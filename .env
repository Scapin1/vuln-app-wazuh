# ==========================================
# Conexión a Base de Datos Externa
# ==========================================
# Apuntar a la IP/hostname del servidor PostgreSQL/TimescaleDB
DATABASE_URL=postgresql://admin:adminpassword@<DB_HOST_IP>:5432/vulnerabilidades_db

# ==========================================
# Configuración de Seguridad
# ==========================================
ENCRYPTION_KEY=_PDHhMGJ7ej8t4jZVgwX4xht5A8RBGwN4mwmUD15NkM=

# ==========================================
# Configuración SSL de Wazuh
# ==========================================
# Poner "true" si el Indexer tiene certificados válidos
WAZUH_VERIFY_SSL=false
# Opcional: ruta al CA bundle si se usa SSL custom
# WAZUH_SSL_CA_PATH=/path/to/ca.pem
